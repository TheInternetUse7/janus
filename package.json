{
  "name": "janus",
  "version": "1.0.0",
  "packageManager": "pnpm@10.13.1",
  "description": "Bi-directional bridge between Discord and Fluxer",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"prisma.config.ts\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"prisma.config.ts\" --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "docker:build": "docker build -t janus-bridge:latest .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheInternetUse7/janus.git"
  },
  "keywords": [
    "discord",
    "fluxer",
    "bridge",
    "chat"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/TheInternetUse7/janus/issues"
  },
  "homepage": "https://github.com/TheInternetUse7/janus#readme",
  "dependencies": {
    "@discordjs/core": "^2.4.0",
    "@discordjs/rest": "^2.6.1",
    "@discordjs/ws": "^2.0.4",
    "@fluxerjs/core": "^1.3.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "axios": "^1.15.0",
    "bullmq": "^5.73.3",
    "crypto-js": "^4.2.0",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.1",
    "ioredis": "^5.10.1",
    "opossum": "^9.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.2",
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
